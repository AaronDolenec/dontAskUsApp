platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  # Use static frameworks for better compatibility with some CocoaPods
  # (avoids issues caused by modular headers). See https://guides.cocoapods.org/using/use-frameworks.html
  use_frameworks! :linkage => :static

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
      target.build_configurations.each do |config|
      # Ensure a modern deployment target for Firebase compatibility
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      # Use a consistent Swift version across plugin targets to avoid Swift mismatch errors
      config.build_settings['SWIFT_VERSION'] = '5.0'
      # Disable bitcode to avoid common archive/runtime issues in CI
      config.build_settings['ENABLE_BITCODE'] = 'NO'
      # Allow firebase (and other) plugins to include non-modular headers inside
      # framework modules when necessary.
      config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
    end
  end

  # Additional workaround: some plugin targets (notably firebase_messaging)
  # include headers that Apple's Clang considers "non-modular". Setting
  # DEFINES_MODULE = NO for those plugin targets prevents them from being
  # treated as Swift/Obj-C modules which avoids the non-modular header error.
  installer.pods_project.targets.each do |target|
    # Only apply DEFINES_MODULE workaround to the Flutter plugin target that
    # triggers non-modular header errors (FLTFirebaseMessagingPlugin). Broadly
    # applying DEFINES_MODULE = NO to all Firebase pods can break module
    # resolution (e.g. "Module 'FirebaseCoreInternal' not found").
    if target.name.end_with?('FLTFirebaseMessagingPlugin')
      target.build_configurations.each do |config|
        config.build_settings['DEFINES_MODULE'] = 'NO'
        config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
        config.build_settings['SWIFT_VERSION'] = '5.0'
        config.build_settings['ENABLE_BITCODE'] = 'NO'
        # Keep the deployment target at least 13.0
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      end
    end
  end
end
